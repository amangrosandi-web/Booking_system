<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sinergi Operasional - ITB & Hazimah</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }

        /* Status Colors */
        .block-pending { background: #fef3c7; border-left: 4px solid #f59e0b; color: #92400e; } 
        .block-approved { background: #e0f2fe; border-left: 4px solid #0ea5e9; color: #075985; }
        .block-ready { background: #dcfce7; border-left: 4px solid #22c55e; color: #166534; }
        .block-on-way { background: #064e3b; border-left: 4px solid #10b981; color: #ecfdf5; } 
        
        .booking-card {
            position: absolute;
            inset: 2px;
            padding: 8px;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            z-index: 20;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            pointer-events: auto;
            overflow: hidden;
            line-height: 1.2;
        }

        .sticky-col { position: sticky; left: 0; background: white; z-index: 50; border-right: 2px solid #e2e8f0; }
        .tab-active { border-bottom: 3px solid #facc15; color: #facc15; }
        .role-btn-active { background-color: #facc15 !important; color: #0f172a !important; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(250, 204, 21, 0.3); }
        .nav-dark { background: #0f172a; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        /* Cell height for better readability of multi-line content */
        .time-row { height: 80px; }
    </style>
</head>
<body class="bg-[#f8fafc] min-h-screen text-slate-800">

    <!-- Modal Login -->
    <div id="login-modal" class="fixed inset-0 bg-black/80 z-[1000] hidden flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-md p-8 rounded-[2.5rem] shadow-2xl">
            <h2 id="login-title" class="text-xl font-black uppercase mb-6 text-slate-900">Login Akses</h2>
            <input type="password" id="pass-input" placeholder="Masukkan Password" class="w-full p-4 border-2 border-slate-100 rounded-2xl mb-4 outline-none focus:border-blue-500 font-bold">
            <div class="flex gap-3">
                <button onclick="closeModal()" class="flex-1 py-4 bg-slate-100 rounded-xl font-black text-[10px] uppercase">Batal</button>
                <button onclick="verifyPassword()" class="flex-1 py-4 bg-slate-900 text-white rounded-xl font-black text-[10px] uppercase">Masuk</button>
            </div>
            <p id="login-error" class="text-red-500 text-[10px] font-bold mt-4 hidden text-center uppercase">Password Salah!</p>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="nav-dark text-white sticky top-0 z-[100] shadow-2xl">
        <div class="container mx-auto px-6 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center space-x-4">
                <div class="flex items-center gap-3 bg-white/5 p-2 rounded-2xl border border-white/10">
                    <img src="https://upload.wikimedia.org/wikipedia/id/thumb/d/d3/Logo_ITB.svg/1200px-Logo_ITB.svg.png" alt="ITB" class="h-10">
                    <div class="w-px h-8 bg-white/20"></div>
                    <div class="bg-white p-1 rounded-lg">
                        <span class="text-slate-900 font-black text-xs px-1 uppercase">Hazimah</span>
                    </div>
                </div>
                <div>
                    <h1 class="text-lg font-extrabold tracking-tight leading-none uppercase italic">Monitoring System</h1>
                    <p id="system-status-indicator" class="text-[9px] text-green-400 font-bold uppercase tracking-widest mt-1">● System Active</p>
                </div>
            </div>
            
            <div class="flex bg-slate-800 rounded-2xl p-1 border border-slate-700">
                <button onclick="attemptSetRole('pemohon')" id="btn-role-pemohon" class="px-5 py-2 rounded-xl text-[10px] font-black transition-all role-btn uppercase">Pemohon</button>
                <button onclick="attemptSetRole('admin')" id="btn-role-admin" class="px-5 py-2 rounded-xl text-[10px] font-black transition-all role-btn uppercase">Admin</button>
                <button onclick="attemptSetRole('petugas')" id="btn-role-petugas" class="px-5 py-2 rounded-xl text-[10px] font-black transition-all role-btn uppercase">Petugas</button>
                <button onclick="attemptSetRole('owner')" id="btn-role-owner" class="px-5 py-2 rounded-xl text-[10px] font-black transition-all role-btn uppercase border-l border-slate-600 ml-1">Owner</button>
            </div>
        </div>
        
        <div class="bg-black/30 border-t border-white/5">
            <div class="container mx-auto px-6 flex space-x-8 text-[11px] font-bold uppercase tracking-widest">
                <button onclick="switchTab('dashboard')" id="tab-dashboard" class="py-4 transition-all tab-active">Dashboard</button>
                <button onclick="switchTab('action')" id="tab-action" class="py-4 transition-all opacity-60 hover:opacity-100">Manajemen</button>
            </div>
        </div>
    </nav>

    <main class="container mx-auto p-4 lg:p-8">
        
        <!-- DASHBOARD -->
        <div id="content-dashboard" class="tab-pane">
            <div class="mb-8 flex flex-col lg:flex-row lg:items-end justify-between gap-6">
                <div>
                    <h2 class="text-3xl font-black text-slate-900 tracking-tighter uppercase italic">Status Armada</h2>
                    <p class="text-sm text-slate-500 font-medium mt-1">Monitoring real-time boking unit Ganesa & Jatinangor.</p>
                </div>
                <div class="flex flex-wrap items-center gap-4">
                    <button onclick="downloadRekap()" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-2xl text-[11px] font-black uppercase">Download Laporan</button>
                    <input type="date" id="dashboard-date" onchange="renderAll()" class="bg-white p-3 rounded-2xl border border-slate-200 font-bold">
                </div>
            </div>

            <div class="bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-slate-200">
                <div class="overflow-x-auto">
                    <table class="w-full text-center border-collapse min-w-[1200px] table-fixed">
                        <thead>
                            <tr class="bg-slate-50 text-slate-500 text-[10px] font-black uppercase tracking-widest border-b">
                                <th class="p-4 sticky-col z-50 w-28 bg-white border-r">Waktu</th>
                                <th class="p-4 border-r" colspan="3">Ambulance Ganesa</th>
                                <th class="p-4 border-r">PMD Ganesa</th>
                                <th class="p-4 border-r">Amb Jatinangor</th>
                                <th class="p-4 border-r">PMD Jatinangor</th>
                            </tr>
                        </thead>
                        <tbody id="schedule-body"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- MANAJEMEN -->
        <div id="content-action" class="tab-pane hidden">
            
            <!-- Owner Control -->
            <div id="owner-control" class="hidden mb-10 bg-slate-900 text-white p-8 rounded-[2rem] shadow-2xl">
                <h3 class="text-xl font-black uppercase italic mb-4">Master Owner Control</h3>
                <div class="flex items-center gap-4">
                    <button id="btn-toggle-system" onclick="toggleSystem()" class="bg-red-500 px-6 py-3 rounded-xl font-black text-[10px] uppercase transition-all active:scale-95"></button>
                    <p class="text-[10px] text-slate-400 font-medium">Khusus Owner: Kontrol pengaktifan fitur boking pemohon.</p>
                </div>
            </div>

            <!-- Pemohon View -->
            <div id="view-pemohon" class="role-view hidden max-w-4xl mx-auto bg-white p-10 rounded-[2.5rem] shadow-2xl border border-slate-100">
                <div id="booking-disabled-msg" class="hidden text-center py-10">
                    <h2 class="text-2xl font-black text-red-600 uppercase">Sistem Nonaktif</h2>
                    <p class="text-slate-500 mt-2 font-bold uppercase text-[10px]">Maaf, pengajuan boking sedang ditutup oleh pusat.</p>
                </div>
                <div id="form-container">
                    <h2 class="text-2xl font-black text-slate-900 uppercase text-center mb-10 tracking-tight">Input Pengajuan Unit</h2>
                    <form onsubmit="handleFormSubmit(event)" class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-6">
                            <input type="text" id="unit" placeholder="Instansi/Unit (Contoh: Hukum, Rektorat)" required class="w-full p-4 border-2 border-slate-100 rounded-2xl bg-slate-50 font-bold outline-none">
                            <select id="campusLocation" onchange="filterVehiclesByCampus()" class="w-full p-4 border-2 border-slate-100 rounded-2xl bg-slate-50 font-bold outline-none">
                                <option value="Ganesa">ITB Ganesa</option>
                                <option value="Jatinangor">ITB Jatinangor</option>
                            </select>
                            <select id="vehicleId" class="w-full p-4 border-2 border-slate-100 rounded-2xl bg-slate-50 font-bold text-blue-600"></select>
                        </div>
                        <div class="space-y-6">
                            <input type="date" id="bookingDate" required class="w-full p-4 border-2 border-slate-100 rounded-2xl bg-slate-50 font-bold">
                            <div class="grid grid-cols-2 gap-4">
                                <input type="time" id="startTime" required class="w-full p-4 border-2 border-slate-100 rounded-2xl bg-slate-50 font-bold">
                                <input type="time" id="endTime" required class="w-full p-4 border-2 border-slate-100 rounded-2xl bg-slate-50 font-bold">
                            </div>
                            <textarea id="desc" class="w-full p-4 border-2 border-slate-100 rounded-2xl bg-slate-50 outline-none" placeholder="Tujuan / Keterangan Acara"></textarea>
                        </div>
                        <button type="submit" class="md:col-span-2 bg-slate-900 text-white py-5 rounded-2xl font-black text-sm uppercase tracking-widest">Kirim Pengajuan</button>
                    </form>
                </div>
            </div>

            <!-- Workflow View (Admin & Petugas) -->
            <div id="view-workflow" class="role-view hidden">
                <div id="workflow-list" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3"></div>
            </div>
        </div>
    </main>

    <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 hidden bg-slate-900 text-white px-8 py-4 rounded-2xl shadow-2xl text-[10px] font-black z-[200] uppercase animate-bounce"></div>

    <script>
        // CONFIGURATION
        const PASSWORDS = {
            owner: 'alifalfa',
            admin: 'adminitb',
            petugas: 'petugas123'
        };

        const vehicles = [
            { id: 'D 9938 AF', loc: 'Ganesa', type: 'Ambulance' }, { id: 'D 9942 AF', loc: 'Ganesa', type: 'Ambulance' },
            { id: 'D 9985 AG', loc: 'Ganesa', type: 'Ambulance' }, { id: 'D 9973 AG', loc: 'Ganesa', type: 'Pemadam' },
            { id: 'D 9940 AG', loc: 'Jatinangor', type: 'Ambulance' }, { id: 'D 9913 AH', loc: 'Jatinangor', type: 'Pemadam' }
        ];

        let bookings = [
            { id: 1, unit: 'SATPAM ITB', date: new Date().toISOString().split('T')[0], vehicle: 'D 9938 AF', startTime: '08:00', endTime: '12:00', status: 'approved', desc: 'Pengamanan Wisuda' }
        ];

        let currentRole = 'pemohon';
        let isSystemActive = true;
        let pendingRole = '';

        function init() {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('dashboard-date').value = today;
            document.getElementById('bookingDate').value = today;
            filterVehiclesByCampus();
            setRole('pemohon');
        }

        function attemptSetRole(r) {
            if (r === 'pemohon') {
                setRole('pemohon');
                return;
            }
            pendingRole = r;
            document.getElementById('login-title').innerText = "Login Sebagai " + r.toUpperCase();
            document.getElementById('pass-input').value = '';
            document.getElementById('login-error').classList.add('hidden');
            document.getElementById('login-modal').classList.remove('hidden');
            document.getElementById('pass-input').focus();
        }

        function closeModal() {
            document.getElementById('login-modal').classList.add('hidden');
        }

        function verifyPassword() {
            const pass = document.getElementById('pass-input').value;
            if (pass === PASSWORDS[pendingRole]) {
                setRole(pendingRole);
                closeModal();
                showToast("Berhasil Masuk sebagai " + pendingRole);
            } else {
                document.getElementById('login-error').classList.remove('hidden');
            }
        }

        function setRole(r) {
            currentRole = r;
            document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('role-btn-active'));
            document.getElementById('btn-role-'+r).classList.add('role-btn-active');
            
            const tabAction = document.getElementById('tab-action');
            if (r === 'owner') tabAction.innerText = "OWNER CONTROL";
            else if (r === 'admin') tabAction.innerText = "ADMIN APPROVAL";
            else if (r === 'petugas') tabAction.innerText = "PETUGAS KERJA";
            else tabAction.innerText = "FORM BOKING";
            
            renderAll();
        }

        function toggleSystem() {
            isSystemActive = !isSystemActive;
            renderAll();
            showToast(isSystemActive ? "Sistem Aktif" : "Sistem Nonaktif");
        }

        function renderAll() {
            renderSchedule();
            renderWorkflow();
            
            const btnToggle = document.getElementById('btn-toggle-system');
            const ind = document.getElementById('system-status-indicator');
            
            if (isSystemActive) {
                btnToggle.innerText = "Nonaktifkan Sistem Boking";
                btnToggle.className = "bg-red-500 px-6 py-3 rounded-xl font-black text-[10px] uppercase transition-all";
                ind.innerText = "● System Active";
                ind.className = "text-[9px] text-green-400 font-bold uppercase mt-1";
            } else {
                btnToggle.innerText = "Aktifkan Sistem Boking";
                btnToggle.className = "bg-green-500 px-6 py-3 rounded-xl font-black text-[10px] uppercase transition-all";
                ind.innerText = "● System Disabled";
                ind.className = "text-[9px] text-red-500 font-bold uppercase mt-1";
            }

            document.getElementById('owner-control').classList.toggle('hidden', currentRole !== 'owner');
            
            if (currentRole === 'pemohon') {
                document.getElementById('form-container').classList.toggle('hidden', !isSystemActive);
                document.getElementById('booking-disabled-msg').classList.toggle('hidden', isSystemActive);
            } else {
                document.getElementById('form-container').classList.remove('hidden');
                document.getElementById('booking-disabled-msg').classList.add('hidden');
            }
        }

        function renderSchedule() {
            const body = document.getElementById('schedule-body');
            const date = document.getElementById('dashboard-date').value;
            body.innerHTML = '';

            for(let h=0; h<24; h++) {
                const hStr = h.toString().padStart(2, '0') + ":00";
                const tr = document.createElement('tr');
                tr.className = "border-b time-row hover:bg-slate-50";
                
                let html = `<td class="sticky-col text-center font-mono font-black border-r text-slate-400 text-[10px]">${hStr}</td>`;
                
                vehicles.forEach(v => {
                    // Cari bokingan yang MULAI pada jam ini
                    const b = bookings.find(item => 
                        item.vehicle === v.id && 
                        item.date === date && 
                        item.startTime === hStr && 
                        item.status !== 'cancelled' && 
                        item.status !== 'finished'
                    );

                    if (b) {
                        // Hitung durasi jam untuk menentukan tinggi blok
                        const startH = parseInt(b.startTime.split(':')[0]);
                        const endH = parseInt(b.endTime.split(':')[0]);
                        const duration = endH - startH;
                        // Tinggi blok = durasi * tinggi baris (80px)
                        const blockHeight = (duration * 80) - 4; 

                        html += `<td class="p-0 border-r relative align-top">
                            <div class="booking-card block-${b.status}" style="height: ${blockHeight}px; margin-top: 2px;">
                                <div class="font-black text-[11px] uppercase mb-1 border-b border-black/10 pb-1">${b.unit}</div>
                                <div class="text-[9px] font-bold mb-1 opacity-80">${b.startTime} - ${b.endTime}</div>
                                <div class="text-[9px] font-medium italic overflow-hidden">${b.desc}</div>
                                <div class="mt-auto text-[7px] font-black uppercase tracking-widest opacity-50">${b.status}</div>
                            </div>
                        </td>`;
                    } else {
                        // Cek apakah jam ini sedang dalam durasi bokingan orang lain (untuk mengosongkan cell)
                        const isUnderOtherBooking = bookings.some(item => 
                            item.vehicle === v.id && 
                            item.date === date && 
                            hStr > item.startTime && hStr < item.endTime && 
                            item.status !== 'cancelled' && item.status !== 'finished'
                        );
                        
                        if (isUnderOtherBooking) {
                            html += `<td class="p-0 border-r bg-slate-50/30"></td>`;
                        } else {
                            html += `<td class="p-0 border-r"></td>`;
                        }
                    }
                });
                tr.innerHTML = html;
                body.appendChild(tr);
            }
        }

        function renderWorkflow() {
            const pView = document.getElementById('view-pemohon');
            const wView = document.getElementById('view-workflow');
            const list = document.getElementById('workflow-list');
            
            if (currentRole === 'pemohon') {
                pView.classList.remove('hidden'); wView.classList.add('hidden');
            } else {
                pView.classList.add('hidden'); wView.classList.remove('hidden');
                list.innerHTML = '';
                let filtered = bookings.filter(b => b.status !== 'finished' && b.status !== 'cancelled');
                
                filtered.forEach(b => {
                    const card = document.createElement('div');
                    card.className = "bg-white p-6 rounded-[2rem] shadow-xl border-t-4 border-slate-900";
                    let action = '';
                    
                    if (currentRole === 'admin') {
                        if (b.status === 'pending') {
                            action = `<div class="grid grid-cols-2 gap-3 mt-4">
                                <button onclick="updateStatus(${b.id}, 'approved')" class="bg-blue-600 text-white text-[9px] py-4 rounded-xl font-black uppercase">Approve</button>
                                <button onclick="updateStatus(${b.id}, 'cancelled')" class="bg-slate-100 text-slate-400 text-[9px] py-4 rounded-xl font-black uppercase">Tolak</button>
                            </div>`;
                        } else { action = `<div class="mt-4 text-[9px] font-black text-center text-slate-300 uppercase">Sudah Verifikasi</div>`; }
                    } else if (currentRole === 'petugas') {
                        if (['approved','ready','on-way'].includes(b.status)) {
                            const lbl = b.status === 'approved' ? 'SIAPKAN UNIT' : b.status === 'ready' ? 'JALAN' : 'SELESAI';
                            const nxt = b.status === 'approved' ? 'ready' : b.status === 'ready' ? 'on-way' : 'finished';
                            action = `<button onclick="updateStatus(${b.id}, '${nxt}')" class="w-full mt-4 bg-green-600 text-white text-[9px] py-4 rounded-xl font-black uppercase">${lbl}</button>`;
                        } else { action = `<div class="mt-4 text-[9px] font-black text-center text-slate-300 uppercase">Menunggu Admin</div>`; }
                    } else if (currentRole === 'owner') {
                        action = `<button onclick="updateStatus(${b.id}, 'cancelled')" class="w-full mt-4 bg-red-100 text-red-600 text-[9px] py-4 rounded-xl font-black uppercase">Cancel Paksa</button>`;
                    }

                    card.innerHTML = `
                        <div class="flex justify-between items-start">
                            <h3 class="font-black text-sm uppercase">${b.unit}</h3>
                            <span class="text-[8px] font-black px-2 py-1 bg-slate-100 rounded-full">${b.status}</span>
                        </div>
                        <p class="text-[10px] text-blue-500 font-bold uppercase">${b.vehicle} | ${b.startTime} - ${b.endTime}</p>
                        <p class="text-[10px] text-slate-500 mt-2 italic">"${b.desc}"</p>
                        ${action}
                    `;
                    list.appendChild(card);
                });
            }
        }

        function updateStatus(id, s) {
            const b = bookings.find(x => x.id === id);
            if(b) { b.status = s; renderAll(); showToast("Status: " + s.toUpperCase()); }
        }

        function handleFormSubmit(e) {
            e.preventDefault();
            if(!isSystemActive) { showToast("Sistem Nonaktif"); return; }
            bookings.push({
                id: Date.now(),
                unit: document.getElementById('unit').value.toUpperCase(),
                date: document.getElementById('bookingDate').value,
                vehicle: document.getElementById('vehicleId').value,
                startTime: document.getElementById('startTime').value,
                endTime: document.getElementById('endTime').value,
                desc: document.getElementById('desc').value,
                status: 'pending'
            });
            e.target.reset();
            switchTab('dashboard');
            showToast("Berhasil Diajukan");
        }

        function switchTab(t) {
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
            document.getElementById('content-'+t).classList.remove('hidden');
            document.querySelectorAll('nav .container button').forEach(b => b.classList.remove('tab-active'));
            document.getElementById('tab-'+t).classList.add('tab-active');
            renderAll();
        }

        function filterVehiclesByCampus() {
            const campus = document.getElementById('campusLocation').value;
            const filtered = vehicles.filter(v => v.loc === campus);
            document.getElementById('vehicleId').innerHTML = filtered.map(v => `<option value="${v.id}">${v.id} - ${v.type}</option>`).join('');
        }

        function showToast(m) {
            const t = document.getElementById('toast'); t.innerText = m; t.classList.remove('hidden');
            setTimeout(() => t.classList.add('hidden'), 2000);
        }

        function downloadRekap() {
            let csv = "ID,UNIT,VEHICLE,DATE,START,END,STATUS,KETERANGAN\n";
            bookings.forEach(b => csv += `${b.id},${b.unit},${b.vehicle},${b.date},${b.startTime},${b.endTime},${b.status},"${b.desc}"\n`);
            const blob = new Blob([csv], { type: 'text/csv' });
            const a = document.createElement('a'); a.href = window.URL.createObjectURL(blob); a.download = 'Laporan_Hazimah.csv'; a.click();
        }

        window.onload = init;
    </script>
</body>
</html>
